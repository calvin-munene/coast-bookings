entrypoint = "package.json"
modules = ["nodejs-22"]

[nix]
channel = "stable-24_05"

[deployment]
# Replit injects DATABASE_URL from its PostgreSQL integration. To use Supabase
# PostgreSQL instead, set DATABASE_PROVIDER=supabase and SUPABASE_DATABASE_URL.
run = ["sh", "-c", "npm run db:migrate && npm run start -- -p ${PORT:-3000}"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 3000
externalPort = 80

[workflows]
runButton = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev -- --hostname 0.0.0.0 --port 3000"
waitForPort = 3000
