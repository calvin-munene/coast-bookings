# Runtime and published Replit URLs
NODE_ENV=development
APP_ENV=sandbox
SEED_DEMO_DATA=false
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ACCOUNT_URL=http://localhost:3000
NEXT_PUBLIC_OPERATIONS_URL=http://localhost:3000
ALLOW_INDEXING=false

# Replit PostgreSQL. Replit injects this after the Database tool is added.
# Do not commit a real connection string or append third-party SSL parameters.
DATABASE_URL=REPLIT_INJECTS_THIS_VALUE

# Clerk identity. Store all secret values in Replit Secrets.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=REPLACE_IN_REPLIT_SECRETS
CLERK_SECRET_KEY=REPLACE_IN_REPLIT_SECRETS
CLERK_WEBHOOK_SIGNING_SECRET=REPLACE_IN_REPLIT_SECRETS
CLERK_INTERNAL_ORGANIZATION_ID=REPLACE_IN_REPLIT_SECRETS

# Replit App Storage bucket IDs
REPLIT_PUBLIC_IMAGES_BUCKET_ID=replace-me
REPLIT_PRIVATE_DOCUMENTS_BUCKET_ID=replace-me
REPLIT_SUPPORT_ATTACHMENTS_BUCKET_ID=replace-me

# Encryption, initial administrator and scheduled-job authentication
APP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
APP_ENCRYPTION_KEY_VERSION=v1
INITIAL_SUPER_ADMIN_EMAIL=admin@example.com
CRON_SHARED_SECRET=replace-with-at-least-24-random-characters

# Whop checkout and verified webhooks
PAYMENT_MODE=sandbox
WHOP_API_KEY=replace-with-whop-api-key
WHOP_WEBHOOK_SECRET=whsec_replace_me
WHOP_COMPANY_ID=biz_replace_me

# Transactional notifications
RESEND_API_KEY=re_replace_me
EMAIL_FROM=Coast Bookings <bookings@example.com>
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=replace-me
META_WHATSAPP_ACCESS_TOKEN=replace-me
META_WHATSAPP_PHONE_NUMBER_ID=replace-me
META_WHATSAPP_APP_SECRET=replace-me
META_WHATSAPP_VERIFY_TOKEN=replace-me
META_GRAPH_API_VERSION=v23.0
META_WHATSAPP_TEMPLATE_NAME=coast_bookings_transactional

# Maps and monitoring
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.replace-me
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
