# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOW_INDEXING=false
NODE_ENV=development
APP_ENV=sandbox
PAYMENT_MODE=mock

# Database: Replit PostgreSQL is the default. Replit injects DATABASE_URL
# automatically after you add its PostgreSQL database integration.
DATABASE_PROVIDER=replit
DATABASE_SSL=auto
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Optional alternative: use Supabase PostgreSQL instead of Replit PostgreSQL.
# Set DATABASE_PROVIDER=supabase and provide its transaction-pooler URL here.
SUPABASE_DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@REGION.pooler.supabase.com:6543/postgres
# DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Optional Supabase Auth and Storage. These can be used while the main database
# remains Replit PostgreSQL; database and identity/storage choices are independent.
AUTH_PROVIDER=supabase
STORAGE_PROVIDER=supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# Data encryption — 32-byte base64 key; rotate using key versions
APP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
APP_ENCRYPTION_KEY_VERSION=v1
INITIAL_SUPER_ADMIN_EMAIL=admin@example.com
CRON_SHARED_SECRET=replace-with-at-least-24-random-characters

# Safaricom Daraja sandbox
DARAJA_ENVIRONMENT=sandbox
DARAJA_CONSUMER_KEY=replace-me
DARAJA_CONSUMER_SECRET=replace-me
DARAJA_SHORTCODE=replace-me
DARAJA_PASSKEY=replace-me
DARAJA_CALLBACK_SECRET=replace-me

# Pesapal sandbox
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=replace-me
PESAPAL_CONSUMER_SECRET=replace-me
PESAPAL_IPN_ID=replace-me

# Notifications
RESEND_API_KEY=replace-me
EMAIL_FROM=Coast Bookings <bookings@example.com>
META_WHATSAPP_ACCESS_TOKEN=replace-me
META_WHATSAPP_PHONE_NUMBER_ID=replace-me
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=replace-me

# Maps and monitoring
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-me
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
