# Application URLs (set the first value to the published Replit app URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ACCOUNT_URL=http://localhost:3000
NEXT_PUBLIC_OPERATIONS_URL=http://localhost:3000
ALLOW_INDEXING=false
NODE_ENV=development
APP_ENV=sandbox

# Replit PostgreSQL. Replit injects DATABASE_URL when a database is added.
# Do not add sslmode=require: Replit's in-app database connection is private.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# Clerk. Add these as Replit Secrets, never as browser source or committed values.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SIGNING_SECRET=whsec_replace_me
CLERK_INTERNAL_ORGANIZATION_ID=org_replace_me

# Replit App Storage bucket IDs. Create three buckets with distinct access scopes.
REPLIT_PUBLIC_IMAGES_BUCKET_ID=replace-me
REPLIT_PRIVATE_DOCUMENTS_BUCKET_ID=replace-me
REPLIT_SUPPORT_ATTACHMENTS_BUCKET_ID=replace-me

# Data encryption and privileged jobs
APP_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
APP_ENCRYPTION_KEY_VERSION=v1
INITIAL_SUPER_ADMIN_EMAIL=admin@example.com
CRON_SHARED_SECRET=replace-with-at-least-24-random-characters

# Payments (sandbox by default)
PAYMENT_MODE=mock
DARAJA_ENVIRONMENT=sandbox
DARAJA_CONSUMER_KEY=replace-me
DARAJA_CONSUMER_SECRET=replace-me
DARAJA_SHORTCODE=replace-me
DARAJA_PASSKEY=replace-me
DARAJA_CALLBACK_SECRET=replace-me
PESAPAL_ENVIRONMENT=sandbox
PESAPAL_CONSUMER_KEY=replace-me
PESAPAL_CONSUMER_SECRET=replace-me
PESAPAL_IPN_ID=replace-me

# Notifications
RESEND_API_KEY=replace-me
EMAIL_FROM=Coast Bookings <bookings@example.com>
META_WHATSAPP_ACCESS_TOKEN=replace-me
META_WHATSAPP_PHONE_NUMBER_ID=replace-me
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=replace-me

# Maps and monitoring
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-me
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
